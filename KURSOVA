    default_keywords = ['password', 'passport', 'finance', 'salary', 'private']
    with open(KEYWORDS_FILE, 'w') as f:
        json.dump(default_keywords, f, indent=4)

    default_extensions = {
        "HIGH": ['.docx', '.pdf', '.xlsx', '.sql', '.db'],
        "MEDIUM": ['.txt', '.json', '.csv'],
        "LOW": ['.mp4', '.mp3', '.jpg', '.png']
    }
    with open(EXTENSIONS_FILE, 'w') as f:
        json.dump(default_extensions, f, indent=4)

    with open(IMPORTANT_DIRS_FILE, 'w') as f:
        json.dump([], f, indent=4)

    with open(OVERRIDE_FILE, 'w') as f:
        json.dump({}, f, indent=4)

    print("[OK] Налаштування скинуто")
